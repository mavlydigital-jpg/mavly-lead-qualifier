# =============================================================================
# Mavly Lead Qualifier — environment variables
# Copy this file to `.env` (same directory) and fill in the values.
# =============================================================================

# --- Database (required) -----------------------------------------------------
# Your Supabase Postgres connection string. In the Supabase dashboard:
#   Project Settings -> Database -> Connection string -> "URI"
# Use the "Transaction" pooler URL (port 6543) for serverless,
# or the "Session" pooler URL (port 5432) for a long-lived dev server.
# Make sure to URL-encode special characters in the password.
DATABASE_URL=postgresql://postgres.PROJECTREF:YOURPASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# --- Local user (optional) ---------------------------------------------------
# Display name shown in the UI for the local single-user account.
OWNER_NAME=David
OWNER_OPEN_ID=local-user

# --- App login (required for the password gate) ------------------------------
# Shared team password. Anyone must type this to reach the qualifier.
# Set the SAME value in Netlify -> Site settings -> Environment variables.
# Leave blank to disable the gate (app stays open).
APP_PASSWORD=

# --- Apify (optional — BBB lead scraper) -------------------------------------
# API token from Apify console -> Settings -> Integrations / API.
# Without it, the "Scrape leads from BBB" button stays disabled.
# Set the SAME value in Netlify -> Site settings -> Environment variables.
APIFY_TOKEN=

# --- Twilio Lookups (optional) -----------------------------------------------
# Without these, the phone-check buttons in the UI disable themselves.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# --- Server (optional) -------------------------------------------------------
PORT=3000
